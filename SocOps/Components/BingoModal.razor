<div class="cyber-overlay fixed inset-0 flex items-center justify-center p-4 z-50">
    <div class="cyber-modal rounded-xl p-6 max-w-xs w-full text-center">
        <div style="font-size: 2.5rem; margin-bottom: 0.75rem; filter: drop-shadow(0 0 8px var(--neon-yellow));">&#x26A1;</div>
        <h2 class="cyber-modal-title mb-2">BINGO!</h2>
        <p class="mb-6" style="font-family: var(--font-body); font-size: 0.95rem; color: var(--text-secondary); letter-spacing: 0.05em; text-transform: uppercase;">Line Secured</p>

        <button
            @onclick="OnDismiss"
            class="cyber-btn w-full py-3 px-6 rounded-lg">
            Continue Mission
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
