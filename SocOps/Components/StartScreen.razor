<div class="landing-root">

    <!-- Animated background decoration -->
    <div class="landing-bg" aria-hidden="true">
        <div class="landing-orb landing-orb--cyan"></div>
        <div class="landing-orb landing-orb--magenta"></div>
        <div class="landing-scan-line"></div>
    </div>

    <div class="landing-content">

        <!-- Hero -->
        <div class="landing-hero">
            <div class="landing-badge">◈ Social Protocol Active ◈</div>
            <h1 class="cyber-title landing-title">SOC&nbsp;OPS</h1>
            <p class="cyber-subtitle landing-subtitle">Social&nbsp;Bingo&nbsp;Experience</p>
            <p class="landing-tagline">Turn every event into a mission.</p>
        </div>

        <!-- Stats strip -->
        <div class="landing-stats">
            <div class="landing-stat">
                <span class="landing-stat-value">25</span>
                <span class="landing-stat-label">Squares</span>
            </div>
            <div class="landing-stat-divider"></div>
            <div class="landing-stat">
                <span class="landing-stat-value">5×5</span>
                <span class="landing-stat-label">Grid</span>
            </div>
            <div class="landing-stat-divider"></div>
            <div class="landing-stat">
                <span class="landing-stat-value">5</span>
                <span class="landing-stat-label">In a Row</span>
            </div>
        </div>

        <!-- Numbered mission steps -->
        <div class="landing-steps">
            <div class="landing-step">
                <span class="landing-step-number">01</span>
                <span class="landing-step-text">Find people who match the squares</span>
            </div>
            <div class="landing-step">
                <span class="landing-step-number">02</span>
                <span class="landing-step-text">Tap a square when you find a match</span>
            </div>
            <div class="landing-step">
                <span class="landing-step-number">03</span>
                <span class="landing-step-text">Get 5 in a row to win!</span>
            </div>
        </div>

        <!-- CTA -->
        <div class="landing-cta">
            <button @onclick="OnStart" class="cyber-btn landing-cta-btn">
                ⟩ Initialize Mission ⟨
            </button>
            <p class="landing-cta-hint">Ready to deploy, agent?</p>
        </div>

    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
