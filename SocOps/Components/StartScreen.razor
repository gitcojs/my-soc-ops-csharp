<div class="flex flex-col items-center justify-center min-h-full p-6" style="background: transparent;">
    <div class="text-center max-w-sm w-full">

        <!-- Logo / Title -->
        <div class="mb-2">
            <h1 class="cyber-title" style="font-size: 3rem; line-height: 1;">
                SOC&nbsp;OPS
            </h1>
        </div>
        <p class="cyber-subtitle mb-8" style="font-size: 0.8rem;">Social &nbsp;Bingo</p>

        <!-- Instructions card -->
        <div class="cyber-instructions rounded-lg p-6 mb-8">
            <h2 class="cyber-label mb-3">Mission Briefing</h2>
            <ul style="list-style: none; margin: 0; padding: 0;" class="space-y-2">
                <li class="cyber-list-item">Find people who match the squares</li>
                <li class="cyber-list-item">Tap a square when you find a match</li>
                <li class="cyber-list-item">Get 5 in a row to win!</li>
            </ul>
        </div>

        <!-- CTA -->
        <button
            @onclick="OnStart"
            class="cyber-btn w-full py-4 px-8 rounded-lg text-lg">
            Initialize Game
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
